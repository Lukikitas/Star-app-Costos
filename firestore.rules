rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function businessDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId));
    }

    function isBusinessMember(businessId) {
      return isSignedIn()
        && businessDoc(businessId).data.members[request.auth.uid] != null;
    }

    function getBusinessRole(businessId) {
      return businessDoc(businessId).data.members[request.auth.uid];
    }

    function isBusinessOwner(businessId) {
      return isBusinessMember(businessId)
        && getBusinessRole(businessId) == "owner";
    }

    function canEditBusinessData(businessId) {
      return isBusinessMember(businessId)
        && (getBusinessRole(businessId) == "owner" || getBusinessRole(businessId) == "editor");
    }

    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /businesses/{businessId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members[request.auth.uid] == "owner";

      // Importante: para poder evaluar `get()` desde subcolecciones sin loop,
      // el read del business se valida sólo con `resource`.
      allow read: if isSignedIn()
        && resource.data.members[request.auth.uid] != null;
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);

      match /supplies/{supplyId} {
        allow read: if isBusinessMember(businessId);
        allow create, update, delete: if canEditBusinessData(businessId);
      }

      match /recipes/{recipeId} {
        allow read: if isBusinessMember(businessId);
        allow create, update, delete: if canEditBusinessData(businessId);
      }

      match /settings/{settingId} {
        allow read: if isBusinessMember(businessId);
        // `categories` se usa para filtros/formularios; permitir edición para miembros
        // (y mantener owner/editor para resto de configuraciones).
        allow create, update, delete: if canEditBusinessData(businessId)
          || (settingId == "categories" && isBusinessMember(businessId));
      }
    }
  }
}
